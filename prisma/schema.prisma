generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Condition {
  id    String @id
  name  String @unique
  items Item[]
}

model Item {
  id           String      @id @default(cuid())
  title        String
  description  String?
  brand        String?
  model        String?
  category     String
  condition    Condition   @relation(fields: [conditionId], references: [id])
  conditionId  String
  notes        String?
  archived     Boolean     @default(false)
  imageGroup   ImageGroup? @relation(fields: [imageGroupId], references: [id])
  imageGroupId String?
  inventory    Inventory?
  listings     Listing[]
  orders       Order[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model ImageGroup {
  id        String            @id @default(cuid())
  name      String?
  images    ImageGroupImage[]
  items     Item[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model Image {
  id        String            @id @default(cuid())
  url       String
  altText   String?
  groups    ImageGroupImage[]
  createdAt DateTime          @default(now())
}

model ImageGroupImage {
  imageGroup   ImageGroup @relation(fields: [imageGroupId], references: [id])
  imageGroupId String
  image        Image      @relation(fields: [imageId], references: [id])
  imageId      String
  sortOrder    Int        @default(0)

  @@id([imageGroupId, imageId])
}

model Inventory {
  id                 String    @id @default(cuid())
  item               Item      @relation(fields: [itemId], references: [id])
  itemId             String    @unique
  quantity           Int       @default(0)
  dateOfLastSale     DateTime?
  dateOfLastRestock  DateTime  @default(now())
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model Listing {
  id              String   @id @default(cuid())
  item            Item     @relation(fields: [itemId], references: [id])
  itemId          String   @unique
  listingTitle    String
  listingDesc     String?
  listedPrice     Float
  freeShipping    Boolean  @default(false)
  listedOnEbay    Boolean  @default(false)
  listedOnMeta    Boolean  @default(false)
  listedOnMercari Boolean  @default(false)
  orders          Order[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model OrderStatus {
  id     String  @id @default(cuid())
  name   String  @unique
  orders Order[]
}

model Customer {
  id                 String    @id @default(cuid())
  firstName          String
  lastName           String
  email              String    @unique
  street             String?
  street2            String?
  city               String?
  state              String?
  zip                String?
  country            String?   @default("US")
  dateOfLastPurchase DateTime?
  orders             Order[]
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model Order {
  id              String       @id @default(cuid())
  item            Item         @relation(fields: [itemId], references: [id])
  itemId          String
  customer        Customer?    @relation(fields: [customerId], references: [id])
  customerId      String?
  orderStatus     OrderStatus  @relation(fields: [statusId], references: [id])
  statusId        String
  listing         Listing?     @relation(fields: [listingId], references: [id])
  listingId       String?
  salePrice       Float
  shippingCost    Float        @default(0)
  trackingCode    String?
  labelUrl        String?
  stripeSessionId String?      @unique
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model PlatformConnection {
  id           String    @id @default(cuid())
  platform     String    @unique
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  shopId       String?
  pageId       String?
  catalogId    String?
  isActive     Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
